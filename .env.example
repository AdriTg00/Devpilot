# =============================================================================
# DevPilot — Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in your values.
# cp backend/.env.example backend/.env
# =============================================================================

# ── Cloud AI Providers (fill in the ones you want to use) ───────────────────
# Get keys at:
#   OpenAI:   https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/settings/keys
#   Google:   https://aistudio.google.com/apikey
#   Groq:     https://console.groq.com/keys

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── Ollama (local, no key needed) ───────────────────────────────────────────

OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_HOST=http://localhost:11434   # Set if Ollama runs on another machine

# ── Auth ─────────────────────────────────────────────────────────────────────

JWT_SECRET=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Defaults to SQLite at backend/.memory/devpilot.db

# DATABASE_URL=sqlite:///./.memory/devpilot.db

# ── URLs ─────────────────────────────────────────────────────────────────────

# BASE_URL=http://localhost:5173   # Used when generating share links

# ── Docker ───────────────────────────────────────────────────────────────────

# COMPOSE_PROJECT_NAME=devpilot
